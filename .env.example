# --- Chain ---
# Public Base Sepolia RPC is fine for reads; swap for Alchemy/Infura if you hit rate limits.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_CHAIN_ID=84532

# ERC-8004 (Base Sepolia) — verified live on-chain via eth_getCode, see docs/erc8004-addresses.md
ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713

# --- ZeroDev (Day 2 / L3) ---
# From https://dashboard.zerodev.app -> Project -> Base Sepolia -> "Bundler & Paymaster RPC"
ZERODEV_RPC=

# --- Wallet (Day 1 / L3) ---
# Owner (sudo) EOA that controls the Kernel smart account. Generate with: npm run wallet:create
OWNER_PRIVATE_KEY=

# --- Quorum (L1b, Day 4) ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
