# --- Demo chain: Base Sepolia + ZeroDev (verified working end-to-end, Day 2) ---
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_CHAIN_ID=84532
# From https://dashboard.zerodev.app -> Project -> Base Sepolia -> "Bundler & Paymaster RPC"
ZERODEV_RPC=

# --- X Layer Testnet + thirdweb (attempted primary chain, blocked on bundler support) ---
# Chain ID verified live via eth_chainId -- it's 1952, NOT 195 (195 is deprecated).
# See docs/erc8004-addresses.md for the chain-id verification trail and
# docs/x-layer-investigation.md for why this isn't the demo chain yet.
XLAYER_TESTNET_RPC_URL=https://testrpc.xlayer.tech
XLAYER_TESTNET_CHAIN_ID=1952
# From https://thirdweb.com/dashboard -> Create Project -> "Client ID"
THIRDWEB_CLIENT_ID=
# Only needed for server-side/backend thirdweb operations; same dashboard project.
THIRDWEB_SECRET_KEY=

# ERC-8004 -- same deterministic address on every deployed chain (Base Sepolia, X Layer
# Testnet, etc.) -- verified live on-chain via eth_getCode, see docs/erc8004-addresses.md
ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713

# --- Wallet owner key (Day 1 / L3, used by both chains) ---
# Owner (sudo) EOA that controls the smart account. Generate with: npm run wallet:create
OWNER_PRIVATE_KEY=

# --- Quorum (L1b, Day 4) ---
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
